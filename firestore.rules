rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /test/{docId} {
      allow get: if true;
    }

    // --- Helpers ---
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // RBAC: Check if the current user is an admin
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'chatshero8@gmail.com'
      );
    }

    // --- Validation Blueprints ---

    function isValidUser(data) {
      let requiredFields = ['uid', 'name', 'email', 'avatar', 'role', 'isAdmin', 'createdAt'];
      let allAllowedFields = ['uid', 'name', 'email', 'avatar', 'role', 'isAdmin', 'createdAt', 'internshipEndDate', 'department', 'target', 'targets', 'todos', 'calendarEvents', 'activityLogs', 'automationGoal'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() <= allAllowedFields.size()
        && data.uid == request.auth.uid
        && data.email == request.auth.token.email
        && data.name is string && data.name.size() <= 100
        && data.avatar is string && data.avatar.size() <= 2000
        && data.role in ['admin', 'Senior IT', 'Junior IT', 'Intern IT', 'Intern Graphic', 'Private', 'pending']
        && data.isAdmin is bool
        && (data.isAdmin == false || isAdmin())
        && (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidAgent(data) {
      let requiredFields = ['name', 'role', 'department', 'avatar', 'ownerId', 'createdAt'];
      let allAllowedFields = ['id', 'name', 'role', 'department', 'avatar', 'ownerId', 'createdAt', 'description', 'owner', 'tokensConsumed', 'powerLevel', 'popularity', 'visibility', 'externalLink', 'imageUrl', 'allowedRoles', 'allowedEmails', 'isDeleted', 'deletedAt'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() <= 30
        && data.name is string && data.name.size() <= 250
        && data.role is string && data.role.size() <= 600
        && data.department is string && data.department.size() <= 150
        && data.avatar is string && data.avatar.size() <= 2000
        && data.ownerId == request.auth.uid
        && (data.createdAt == request.time || data.createdAt == existing().createdAt)
        && (!('description' in data) || (data.description is string && data.description.size() <= 10000))
        && (!('externalLink' in data) || (data.externalLink is string && data.externalLink.size() <= 2000))
        && (!('imageUrl' in data) || (data.imageUrl == null || (data.imageUrl is string && data.imageUrl.size() <= 1000)))
        && (!('visibility' in data) || (data.visibility in ['public', 'private']))
        && (!('allowedRoles' in data) || (data.allowedRoles is list))
        && (!('allowedEmails' in data) || (data.allowedEmails is list));
    }

    function isValidWidget(data) {
      let requiredFields = ['title', 'department', 'type', 'ownerId', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.title is string && data.title.size() <= 100
        && data.department is string && data.department.size() <= 100
        && data.type in ['metric', 'chart_line', 'chart_bar']
        && data.ownerId == request.auth.uid
        && (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidGlobalEvent(data) {
      let requiredFields = ['type', 'userId', 'userName', 'message', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.type in ['agent_created', 'target_hit', 'announcement', 'sales_closed', 'it_project_live']
        && data.userId == request.auth.uid
        && data.userName is string && data.userName.size() <= 100
        && data.message is string && data.message.size() <= 1000
        && data.createdAt == request.time;
    }

    function isValidTemplate(data) {
      let requiredFields = ['name', 'department', 'type', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.name is string && data.name.size() <= 100
        && data.department is string && data.department.size() <= 100
        && data.type is string && data.type.size() <= 100
        && (data.createdAt == request.time || data.createdAt == existing().createdAt);
    }

    function isValidAllowedEmail(data) {
      let requiredFields = ['email', 'addedAt'];
      return data.keys().hasAll(requiredFields)
        && data.keys().size() == 2
        && data.email is string && data.email.size() <= 128
        && data.addedAt == request.time;
    }

    function isValidTask(data) {
      let requiredFields = ['title', 'status', 'date', 'priority', 'assigneeId', 'assignedById', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && data.title is string && data.title.size() <= 200
        && data.status in ['todo', 'in-progress', 'in-review', 'done']
        && data.date is string && data.date.size() <= 64
        && data.priority in ['low', 'medium', 'high', 'urgent']
        && (data.assigneeId == '' || isValidId(data.assigneeId))
        && isValidId(data.assignedById)
        && (data.createdAt == request.time || data.createdAt == existing().createdAt)
        && (!('updatedAt' in data) || data.updatedAt == request.time || data.updatedAt == existing().updatedAt);
    }

    function isValidNotification(data) {
      let requiredFields = ['userId', 'senderId', 'title', 'message', 'type', 'read', 'createdAt'];
      return data.keys().hasAll(requiredFields)
        && isValidId(data.userId)
        && isValidId(data.senderId)
        && data.title is string && data.title.size() <= 200
        && data.message is string && data.message.size() <= 1000
        && data.type in ['task_assigned', 'task_progress', 'task_correction', 'info']
        && data.read is bool
        && data.createdAt == request.time;
    }

    // --- Collections ---

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isEmailVerified() && isValidUser(incoming()) && isValidId(userId);
      allow update: if isEmailVerified() && isValidId(userId) && (
        isAdmin() || (
          isOwner(userId) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'avatar', 'todos', 'targets', 'calendarEvents', 'activityLogs', 'automationGoal', 'department', 'target', 'internshipEndDate']) &&
          isValidUser(incoming())
        )
      );
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if isSignedIn() && (
        resource.data.assigneeId == request.auth.uid || 
        resource.data.assignedById == request.auth.uid ||
        isAdmin()
      );
      allow create: if isEmailVerified() && isValidTask(incoming()) && incoming().assignedById == request.auth.uid;
      allow update: if isEmailVerified() && isValidId(taskId) && (
        isAdmin() || (
          (existing().assignedById == request.auth.uid || existing().assigneeId == request.auth.uid) &&
          isValidTask(incoming()) &&
          incoming().assignedById == existing().assignedById &&
          incoming().createdAt == existing().createdAt
        )
      );
      allow delete: if isEmailVerified() && (isAdmin() || existing().assignedById == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isEmailVerified() && isValidNotification(incoming()) && incoming().senderId == request.auth.uid;
      allow update: if isEmailVerified() && isOwner(existing().userId) && 
        incoming().diff(existing()).affectedKeys().hasOnly(['read']) &&
        incoming().read is bool;
      allow delete: if isEmailVerified() && (isOwner(existing().userId) || isAdmin());
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }

    match /agents/{agentId} {
      allow read: if isSignedIn() && (
        !existing().keys().contains('visibility') || 
        existing().visibility == 'public' || 
        existing().ownerId == request.auth.uid || 
        isAdmin() ||
        (existing().keys().contains('allowedRoles') && existing().allowedRoles.size() > 0 && request.auth.token.role in existing().allowedRoles) ||
        (existing().keys().contains('allowedEmails') && existing().allowedEmails.size() > 0 && request.auth.token.email in existing().allowedEmails)
      );
      allow create: if isEmailVerified() && isValidAgent(incoming()) && isValidId(agentId);
      allow update: if isEmailVerified() && isValidId(agentId) && (
        isAdmin() || (
          isOwner(existing().ownerId) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'tokensConsumed', 'powerLevel', 'popularity', 'imageUrl', 'avatar', 'role', 'department', 'visibility', 'externalLink', 'allowedRoles', 'allowedEmails', 'isDeleted', 'deletedAt', 'owner', 'ownerId', 'createdAt']) &&
          isValidAgent(incoming())
        )
      );
      allow delete: if isEmailVerified() && isValidId(agentId) && (isAdmin() || isOwner(existing().ownerId));
    }

    match /widgets/{widgetId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidWidget(incoming()) && isValidId(widgetId);
      allow update: if isAdmin() && isValidWidget(incoming()) && isValidId(widgetId);
      allow delete: if isAdmin() && isValidId(widgetId);
    }

    match /global_events/{eventId} {
      allow read: if isSignedIn();
      allow create: if isEmailVerified() && isValidGlobalEvent(incoming()) && isValidId(eventId);
      allow update, delete: if false;
    }

    match /templates/{templateId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidTemplate(incoming()) && isValidId(templateId);
    }

    match /allowedEmails/{emailId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidAllowedEmail(incoming()) && isValidId(emailId);
    }

    match /settings/{docId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
